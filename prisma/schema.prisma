generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id           Int      @id @default(1)
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Memory {
  id        String   @id @default(uuid())
  type      String
  url       String
  caption   String?
  section   String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Settings {
  id             Int      @id @default(1)
  title          String   @default("🎉 Happy Birthday, My Amazing Friend! 🎉")
  subtitle       String   @default("Thank you for being one of the most wonderful people in my life.")
  letterText     String
  musicUrl       String   @default("/media/default_music.mp3")
  daysCelebrated Int      @default(365)
  updatedAt      DateTime @updatedAt
}
